<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#142133">

    <!-- TOP BAR -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <!-- DATE + DAY LEFT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/dayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/iceland_regular" />

            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B8C7D9"
                android:textSize="12sp"
                android:fontFamily="@font/iceland_regular" />
        </LinearLayout>

        <!-- LOGO CENTER -->
        <ImageView
            android:id="@+id/logoCenter"
            android:layout_width="102dp"
            android:layout_height="102dp"
            android:layout_centerInParent="true"
            android:src="@mipmap/ic_launcher"
            android:clipToOutline="true"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:contentDescription="Carabuff Logo" />

    </RelativeLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- CARABUFF HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <!-- CARABUFF LEFT -->
                <ImageView
                    android:id="@+id/carabuffHome"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/carabuff1"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:contentDescription="Carabuff" />

                <!-- WELCOME + THOUGHT RIGHT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back 👋"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/iceland_regular"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/carabuffThought"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="42dp"
                        android:background="@drawable/bg_thought_bubble"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:text="Let’s hit your goals today 💪"
                        android:textColor="#0F1F33"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/iceland_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- ASK CARABUFF -->
            <LinearLayout
                android:id="@+id/btnAskCarabuff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_signup_card"
                android:padding="18dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/carabuff1"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Ask Carabuff" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ask Carabuff 🐃"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:fontFamily="@font/iceland_regular" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food, workouts, fitness advice, and healthy tips"
                        android:textColor="#D6E2F2"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/iceland_regular" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/iceland_regular" />
            </LinearLayout>

            <!-- CALORIES CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_signup_card"
                android:padding="20dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nutrition Overview"
                    android:textColor="#DDE8F5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/iceland_regular" />

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 0 Calories"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/iceland_regular" />

                <ProgressBar
                    android:id="@+id/progressCalories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="14dp"
                    android:indeterminate="false"
                    android:progress="0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="18dp">

                    <TextView
                        android:id="@+id/tvProtein"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Protein: 0 / 0g"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/iceland_regular" />

                    <TextView
                        android:id="@+id/tvCarbs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carbs: 0 / 0g"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/iceland_regular" />

                    <TextView
                        android:id="@+id/tvFats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fats: 0 / 0g"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/iceland_regular" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddFood"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_signup_button"
                    android:text="Add Food"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/iceland_regular" />
            </LinearLayout>

            <!-- WORKOUT CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_signup_card"
                android:padding="20dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workout Progress"
                    android:textColor="#DDE8F5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/iceland_regular" />

                <TextView
                    android:id="@+id/tvWorkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 0 minutes"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/iceland_regular" />

                <ProgressBar
                    android:id="@+id/progressWorkout"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="14dp"
                    android:indeterminate="false"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvCaloriesBurned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Burned: 0 kcal 🔥"
                    android:textColor="#FFB26B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/iceland_regular" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddWorkout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_signup_button"
                    android:text="Workout Now"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/iceland_regular" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <include
        layout="@layout/bottom_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>