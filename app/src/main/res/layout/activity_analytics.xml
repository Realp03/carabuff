<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#1E2A38"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 📜 SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavbar">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="80dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 📊 HEADER -->
            <TextView
                android:text="📊 Progress Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- 🔥 TODAY SUMMARY -->
            <LinearLayout
                android:orientation="vertical"
                android:background="#263544"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🔥 Today Summary"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTodayCalories"
                    android:text="Calories: 0"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTodayBurn"
                    android:text="Burned: 0"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTodayNet"
                    android:text="Net: 0"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 📅 CALENDAR -->
            <LinearLayout
                android:orientation="vertical"
                android:background="#263544"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="📅 Activity Calendar"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 📈 WEEKLY GRAPH -->
            <LinearLayout
                android:orientation="vertical"
                android:background="#263544"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="📈 Weekly Progress"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="(Coming Soon: Graph)"
                    android:textColor="#B0BEC5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 🍔 MACROS -->
            <LinearLayout
                android:orientation="vertical"
                android:background="#263544"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🍔 Avg Macros Per Day"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartMacros"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"/>
            </LinearLayout>

            <!-- 🏆 RECORDS -->
            <LinearLayout
                android:orientation="vertical"
                android:background="#263544"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🏆 Records"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- ✅ FIXED TEXTVIEWS -->
                <TextView
                    android:id="@+id/tvHighestCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvLowestCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvHighestBurn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvLowestBurn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvMaxWorkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvMinWorkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 FIXED NAVBAR INCLUDE -->
    <include
        android:id="@+id/bottomNavbar"
        layout="@layout/bottom_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>

</RelativeLayout>