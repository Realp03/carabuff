<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/step3Scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2A38"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/step3Content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- HEADER -->
        <TextView
            android:id="@+id/tvStep3Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lifestyle Questions"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:fontFamily="@font/iceland_regular"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvStep3Subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Answer a few final questions so Carabuff can personalize your recommendations."
            android:textColor="#B8C7D9"
            android:textSize="14sp"
            android:layout_marginBottom="22dp" />

        <!-- CARD -->
        <LinearLayout
            android:id="@+id/lifestyleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_signup_card"
            android:padding="18dp"
            android:layout_marginBottom="22dp">

            <!-- QUESTION 1 -->
            <TextView
                android:id="@+id/tvQuestion1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Are you willing to change your lifestyle?"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/lifestyleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/yesBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yes"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#3A8DFF" />

                <RadioButton
                    android:id="@+id/noBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="No"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#3A8DFF" />
            </RadioGroup>

            <!-- QUESTION 2 -->
            <TextView
                android:id="@+id/tvQuestion2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How much time can you spend daily?"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/timeSpinner"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <!-- QUESTION 3 -->
            <TextView
                android:id="@+id/tvQuestion3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How active are you daily?"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/activitySpinner"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/input_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                android:id="@+id/tvStep3Note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="These answers help tailor your plan, goals, and workout recommendations."
                android:textColor="#AFC0D4"
                android:textSize="12sp"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- STEP INDICATOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/stepOne"
                android:layout_width="48dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_step_inactive" />

            <View
                android:id="@+id/stepTwo"
                android:layout_width="48dp"
                android:layout_height="6dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_step_inactive" />

            <View
                android:id="@+id/stepThree"
                android:layout_width="48dp"
                android:layout_height="6dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_step_active" />
        </LinearLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/prevBtn"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="Previous"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/iceland_regular"
                android:background="@drawable/bg_signup_button" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/nextBtn"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Finish"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/iceland_regular"
                android:background="@drawable/bg_signup_button" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>