<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resultScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2A38"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/resultContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:id="@+id/carabuffSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="18dp">

            <ImageView
                android:id="@+id/carabuffSprite"
                android:layout_width="125dp"
                android:layout_height="150dp"
                android:src="@drawable/carabuff1"
                android:scaleType="centerInside"
                android:contentDescription="Carabuff Sprite" />

            <TextView
                android:id="@+id/carabuffThought"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginBottom="22dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="#FFFFFF"
                android:padding="12dp"
                android:text="..."
                android:textColor="#1E2A38"
                android:textSize="14sp"
                android:fontFamily="@font/iceland_regular" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Fitness Result"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="@font/iceland_regular"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvResultSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carabuff created a personalized starting point based on your body data."
            android:textColor="#B8C7D9"
            android:textSize="14sp"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_signup_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvResultLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Body Status Overview"
                android:textColor="#AFC0D4"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvBMI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI: --"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal: --"
                android:textColor="#8EE3A1"
                android:textSize="18sp"
                android:fontFamily="@font/iceland_regular" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/macrosCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_signup_card"
            android:padding="18dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvMacrosTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended Daily Intake"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#243345"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvCaloriesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textColor="#AFC0D4"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories: --"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="@font/iceland_regular"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:background="#243345"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textColor="#AFC0D4"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein: --"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/iceland_regular"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:background="#243345"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs"
                        android:textColor="#AFC0D4"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs: --"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/iceland_regular"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#243345"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fats"
                    android:textColor="#AFC0D4"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvFats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fats: --"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/iceland_regular"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFollow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Trust Carabuff 🐃"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:fontFamily="@font/iceland_regular"
            android:background="@drawable/bg_signup_button"
            android:layout_marginBottom="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCustom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Customize Your Journey ⚙️"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:fontFamily="@font/iceland_regular"
            android:background="@drawable/bg_signup_button" />

    </LinearLayout>
</ScrollView>