<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/planScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E2A38"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/planContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <!-- HEADER -->
        <TextView
            android:id="@+id/tvPlanTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Plan 🔥"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="@font/iceland_regular"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPlanSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Here’s your personalized nutrition and workout starting point from Carabuff."
            android:textColor="#B8C7D9"
            android:textSize="14sp"
            android:layout_marginBottom="18dp" />

        <!-- PLAN CARD -->
        <LinearLayout
            android:id="@+id/planCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_signup_card"
            android:padding="18dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/tvPlanOverviewLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plan Overview"
                android:textColor="#AFC0D4"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvPlanBMI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI: --"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPlanGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goal: --"
                android:textColor="#8EE3A1"
                android:textSize="18sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#243345"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textColor="#AFC0D4"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvPlanCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories: --"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="@font/iceland_regular"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:background="#243345"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textColor="#AFC0D4"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvPlanProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein: --"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/iceland_regular"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:background="#243345"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs"
                        android:textColor="#AFC0D4"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvPlanCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs: --"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/iceland_regular"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#243345"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fats"
                    android:textColor="#AFC0D4"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvPlanFats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fats: --"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/iceland_regular"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- WORKOUT CARD -->
        <LinearLayout
            android:id="@+id/workoutCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_signup_card"
            android:padding="18dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/tvWorkoutTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Workout Time ⏱"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="@font/iceland_regular"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvWorkoutSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose how long you want to train each day."
                android:textColor="#B8C7D9"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/spinnerWorkout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/input_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:popupBackground="#FFFFFF"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Get Started 🚀"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:fontFamily="@font/iceland_regular"
            android:background="@drawable/bg_signup_button" />

    </LinearLayout>
</ScrollView>