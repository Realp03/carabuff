<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#142133"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back Button"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Food 🍗"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/iceland_regular" />

        <ImageView
            android:id="@+id/btnHelp"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Help Button"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- MAIN CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_signup_card"
        android:padding="18dp"
        android:elevation="4dp">

        <!-- INPUT -->

        <!-- SEARCH BUTTON -->
        <EditText
            android:id="@+id/etFood"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:fontFamily="@font/iceland_regular"
            android:gravity="center_vertical"
            android:hint="Search food (e.g. egg)"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#5F6B7A"
            android:textSize="17sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSearchFood"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_signup_button"
            android:text="Search Food 🔎"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/iceland_regular" />

        <!-- LOADING -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- RESULT LABEL -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:text=""
            android:textColor="#D9E2F1"
            android:textSize="14sp"
            android:fontFamily="@font/iceland_regular" />

        <!-- RESULTS LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFoods"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_food" />

    </LinearLayout>

</LinearLayout>